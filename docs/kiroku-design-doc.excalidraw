      "name": "Functional Requirements"
    },
    {
      "id": "34hxCEVaUllGa2Cv4YbNl",
      "type": "text",
      "x": -208.9285714285702,
      "y": 1428.7976190476195,
      "width": 1616.859130859375,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": "gSBJQzEd44jnog3kvJ8_n",
      "index": "ah",
      "roundness": null,
      "seed": 1686018220,
      "version": 802,
      "versionNonce": 232467348,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776685833829,
      "link": null,
      "locked": false,
      "text": "- Local First: all data lives in the browser (IndexDB). No server, no account, no internet required after the first load.\n- Performance: block edits must feel instant (<16ms). AI skeleton shown within 100ms of submitting prompt.\n- Type Safety: full typescript coverage. Block schema is the single source of truth across the whole codebase. \n- Resillience: a failed AI call never corrupts editor state. Error shown inline, editor stay usable. \n- Accessibility: keyboard navigation throughout. Slash menu navigable with arrow keys + Enter.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Local First: all data lives in the browser (IndexDB). No server, no account, no internet required after the first load.\n- Performance: block edits must feel instant (<16ms). AI skeleton shown within 100ms of submitting prompt.\n- Type Safety: full typescript coverage. Block schema is the single source of truth across the whole codebase. \n- Resillience: a failed AI call never corrupts editor state. Error shown inline, editor stay usable. \n- Accessibility: keyboard navigation throughout. Slash menu navigable with arrow keys + Enter.",
      "autoResize": true,
      "lineHeight": 1.25
    },
