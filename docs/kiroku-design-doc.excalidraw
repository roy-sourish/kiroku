      "isDeleted": false,
      "boundElements": null,
      "updated": 1776685136072,
      "link": null,
      "locked": false,
      "text": "AI Generation - Claude/ChatGPT\n- /ai command opens up the prompt input box\n- Claude/ChatGPT API generates block JSON\n- Skeleton loader while generating content\n- Generated block inserted inline\n\n@NOTE: need to figure out a free API option\nwill keep this feature till the end.  ",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AI Generation - Claude/ChatGPT\n- /ai command opens up the prompt input box\n- Claude/ChatGPT API generates block JSON\n- Skeleton loader while generating content\n- Generated block inserted inline\n\n@NOTE: need to figure out a free API option\nwill keep this feature till the end.  ",
      "autoResize": true,
      "lineHeight": 1.25
    },
